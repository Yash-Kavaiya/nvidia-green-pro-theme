  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6F806A"
      }
    },
    {
      "name": "Documentation",
      "scope": [
        "comment.documentation",
        "comment.block.documentation",
        "storage.type.class.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7D9276"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key"
      ],
      "settings": {
        "foreground": "#A6E22E"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "constant.regexp"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#B8FF5C"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
