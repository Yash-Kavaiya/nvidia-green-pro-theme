  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#64705E"
      }
    },
    {
      "name": "Documentation",
      "scope": [
        "comment.documentation",
        "comment.block.documentation",
        "storage.type.class.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#596A52"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key"
      ],
      "settings": {
        "foreground": "#3F7800"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "constant.regexp"
      ],
      "settings": {
        "fontStyle": "bold",
